    # Magento 2 (root = pub/). Provisional; refined/validated in Phase 7.
    location ~* ^/(app|vendor|generated|var|lib|tools|setup|update|dev|phpserver)/ { deny all; }

    location / {
        try_files $uri $uri/ /index.php$is_args$args;
    }

    location /static/ {
        location ~ ^/static/version\d*/ { rewrite ^/static/version\d*/(.*)$ /static/$1 last; }
        location ~* \.(ico|jpg|jpeg|png|gif|svg|svgz|webp|js|css|eot|ttf|otf|woff|woff2|json|map)$ {
            add_header Cache-Control "public, max-age=31536000";
            # Developer mode: materialise assets not yet on disk via static.php. The rewrite's
            # own capture ($1 = full path after /static/) is what must reach static.php — inside
            # this extension location the location-regex $1 would only be the file extension.
            if (!-f $request_filename) { rewrite ^/static/?(.*)$ /static.php?resource=$1 last; }
        }
        if (!-f $request_filename) { rewrite ^/static/?(.*)$ /static.php?resource=$1 last; }
    }

    location /media/ {
        try_files $uri $uri/ /get.php$is_args$args;
    }

    location ~ ^/(index|get|static|errors/report|errors/404|errors/503|health_check)\.php$ {
        try_files $uri =404;
        fastcgi_split_path_info ^(.+\.php)(/.+)$;
        fastcgi_pass unix:{{PHP_SOCK}};
        include {{BREW_PREFIX}}/etc/nginx/fastcgi.conf;
        fastcgi_param HTTPS on;
        fastcgi_read_timeout 1800s;
{{MAGE_PARAMS}}
{{PHP_VALUE_BLOCK}}
    }
    location ~ \.php$ { return 404; }
