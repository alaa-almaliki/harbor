# Harbor vhost: {{NAME}} ({{FRAMEWORK}}, php {{PHP_VER}}) — generated, do not edit.
server {
    listen 127.0.0.1:80;
    server_name {{SERVER_NAMES}};
    return 301 https://$host$request_uri;
}
{{MAP_BLOCK}}
server {
    listen 127.0.0.1:443 ssl;
    http2 on;
    server_name {{SERVER_NAMES}};
    root {{DOCROOT}};
    index index.php index.html;

    ssl_certificate {{CERT}};
    ssl_certificate_key {{CERT_KEY}};

    client_max_body_size 128M;
    charset utf-8;
    access_log {{LOG_DIR}}/site-{{NAME}}.access.log;
    error_log  {{LOG_DIR}}/site-{{NAME}}.error.log;
{{CUSTOM_INCLUDE}}
{{BODY}}
}
