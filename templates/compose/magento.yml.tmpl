# Harbor per-project stack: {{NAME}} (Magento). MySQL + OpenSearch + RabbitMQ.
# Loopback-bound; RAM-capped (OpenSearch heap, lean MySQL).
name: harbor-{{NAME}}

services:
  mysql:
    image: {{DB_IMAGE}}
    restart: unless-stopped
    # native auth plugin so older PHP clients (7.2/7.3) can connect over TCP
    command: ["--performance-schema=OFF", "--innodb-buffer-pool-size={{MYSQL_POOL}}", "--default-authentication-plugin=mysql_native_password"]
    environment:
      MYSQL_DATABASE: "{{DB_NAME}}"
      MYSQL_USER: "{{DB_USER}}"
      MYSQL_PASSWORD: "{{DB_PASS}}"
      MYSQL_ROOT_PASSWORD: "{{DB_ROOT_PASS}}"
    ports:
      - "127.0.0.1:{{DB_PORT}}:3306"
    volumes:
      - dbdata:/var/lib/mysql
    healthcheck:
      test: ["CMD", "mysqladmin", "ping", "-h", "127.0.0.1", "-uroot", "-p{{DB_ROOT_PASS}}"]
      interval: 5s
      timeout: 3s
      retries: 40

  opensearch:
    image: opensearchproject/opensearch:2.19.0
    restart: unless-stopped
    environment:
      - discovery.type=single-node
      - bootstrap.memory_lock=true
      - "OPENSEARCH_JAVA_OPTS=-Xms{{OS_HEAP}} -Xmx{{OS_HEAP}}"
      - "DISABLE_SECURITY_PLUGIN=true"
      - "DISABLE_INSTALL_DEMO_CONFIG=true"
    ulimits:
      memlock: { soft: -1, hard: -1 }
    ports:
      - "127.0.0.1:{{OPENSEARCH_PORT}}:9200"
    volumes:
      - osdata:/usr/share/opensearch/data
    healthcheck:
      test: ["CMD-SHELL", "curl -sf http://127.0.0.1:9200/_cluster/health >/dev/null || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 40

  rabbitmq:
    image: rabbitmq:3.13-management-alpine
    restart: unless-stopped
    ports:
      - "127.0.0.1:{{RABBITMQ_PORT}}:5672"
      - "127.0.0.1:{{RABBITMQ_UI_PORT}}:15672"
    volumes:
      - mqdata:/var/lib/rabbitmq
    healthcheck:
      test: ["CMD", "rabbitmq-diagnostics", "-q", "ping"]
      interval: 10s
      timeout: 5s
      retries: 30

volumes:
  dbdata:
  osdata:
  mqdata:
