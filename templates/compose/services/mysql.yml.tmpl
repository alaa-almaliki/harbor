  # Primary database (MySQL or MariaDB via services.mysql). DB_COMMAND is engine-aware.
  mysql:
    image: {{DB_IMAGE}}{{DB_PLATFORM}}
    restart: unless-stopped
    command: {{DB_COMMAND}}
    environment:
      MYSQL_DATABASE: "{{DB_NAME}}"
      MYSQL_USER: "{{DB_USER}}"
      MYSQL_PASSWORD: "{{DB_PASS}}"
      MYSQL_ROOT_PASSWORD: "{{DB_ROOT_PASS}}"
    ports:
      - "127.0.0.1:{{DB_PORT}}:3306"
    volumes:
      - dbdata:/var/lib/mysql
    healthcheck:
      test: ["CMD", "mysqladmin", "ping", "-h", "127.0.0.1", "-uroot", "-p{{DB_ROOT_PASS}}"]
      interval: 5s
      timeout: 3s
      retries: 40
