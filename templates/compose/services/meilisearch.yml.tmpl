  meilisearch:
    image: {{MEILISEARCH_IMAGE}}
    restart: unless-stopped
    environment:
      MEILI_ENV: "development"
      MEILI_NO_ANALYTICS: "true"
      MEILI_MASTER_KEY: "{{MEILI_MASTER_KEY}}"
      MEILI_MAX_INDEXING_MEMORY: "{{MEILI_MEMORY}}"
    ports:
      - "127.0.0.1:{{MEILI_PORT}}:7700"
    volumes:
      - meilidata:/meili_data
    healthcheck:
      test: ["CMD", "curl", "-sf", "http://127.0.0.1:7700/health"]
      interval: 10s
      timeout: 5s
      retries: 30
