# ───────────────────────── macOS / editors ─────────────────────────
.DS_Store
*.swp
*~
.idea/
.vscode/

# ─────────────── Claude Code (share settings.json + skills, not local overrides) ───────────────
.claude/settings.local.json

# ─────────────── Harbor rendered config (generated by `harbor setup`) ───────────────
# Source lives in templates/ (tracked); etc/ is rendered output, machine-specific.
/etc/

# ───────────────────── Runtime state (sockets, pids, logs, allocations) ─────────────────────
# var/run/*.sock, *.pid · var/log/* · var/ports/* · var/lock · var/{default-php,xdebug,cert-sans}
/var/*
!/var/.gitkeep

# ─────────────────── TLS certs + CA bundle (sensitive / machine-specific) ───────────────────
/certs/*
!/certs/.gitkeep

# ───────────────────────────── Database dumps & backups ─────────────────────────────
/backups/db/*
!/backups/db/.gitkeep

# ───────────────── User projects (each is its own codebase / git repo) ─────────────────
# Harbor does not track project source; per-project committable config (harbor.yml,
# import-rules, hooks/) belongs to each project's OWN repo, not Harbor's.
/projects/*
!/projects/.gitkeep

# ─────────────────── Generated shared docker stack (from templates/) ───────────────────
# Keep docker/ for any committed base assets; ignore the generated compose files.
/docker/docker-compose.yml
/docker/sandbox.yml

# ───────────────────────────── Stray runtime artifacts ─────────────────────────────
*.log
*.pid
*.sock
